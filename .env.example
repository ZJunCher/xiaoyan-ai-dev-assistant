# 大模型与向量模型，使用阿里百炼 OpenAI 兼容接口。
API_KEY=

# MySQL 与 Redis，本地可按实际环境覆盖默认连接。
MYSQL_URL=jdbc:mysql://localhost:3307/team_knowledge?serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_USERNAME=root
MYSQL_PASSWORD=
REDIS_HOST=localhost
REDIS_PORT=6379

# Pinecone 默认关闭，真实部署或演示时再开启。
PINECONE_ENABLED=false
PINECONE_API_KEY=
PINECONE_INDEX=team-knowledge
PINECONE_ENVIRONMENT=
PINECONE_PROJECT_ID=

# Reranker 默认关闭，避免本地开发依赖外部精排服务。
RERANKER_ENABLED=false
SILICONFLOW_API_KEY=
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
